---
const agents = [
  {
    name: "Abacus Fantasy Golf Picker",
    slug: "golf-picker",
    description: "Deep dives historical results, current form, and course fit for each golfer in weekly field.",
    tags: ["OpenAI", "LangChain"],
    embedUrl: "https://pga-pickem-dashboard-zaqvfj.abacusai.app",
  },
  {
    name: "Junk Email Screener",
    slug: "email-screener",
    description: "Reviews email inbox, scores emails, deletes emails with a junk score over threshold.",
    tags: ["RAG", "Pinecone"],
  },
  {
    name: "Daily Christian Devotional",
    slug: "daily-devotional",
    description: "Provides daily devotional for study to email.",
    tags: ["Python", "Pandas"],
  }
];
---

<html>
  <head>
    <title>Conor Moe | AI Agents</title>
    <style>
      body {
        font-family: system-ui;
        background: #0f172a;
        color: white;
        margin: 0;
        padding: 40px;
      }

      h1 {
        text-align: center;
        margin-bottom: 40px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
        max-width: 1000px;
        margin: auto;
      }

      .card {
        background: #1e293b;
        padding: 20px;
        border-radius: 12px;
        text-decoration: none;
        color: white;
        transition: 0.2s;
      }

      .card:hover {
        transform: translateY(-5px);
        background: #334155;
      }

      .tags {
        margin-top: 10px;
      }

      .tag {
        background: #475569;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        margin-right: 5px;
      }
    </style>
  </head>

  <body>
    <h1>My AI Agents</h1>

    <div class="grid">
      {agents.map(agent => (
        <a href={`/agents/${agent.slug}`} class="card">
          <h2>{agent.name}</h2>
          <p>{agent.description}</p>

          <div class="tags">
            {agent.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </body>
</html>
