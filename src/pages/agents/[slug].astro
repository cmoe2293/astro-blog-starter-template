---
import { agents } from "../index.astro";

export function getStaticPaths() {
  return agents.map(agent => ({
    params: { slug: agent.slug },
    props: { agent },
  }));
}

const { agent } = Astro.props;
---

<html>
  <head>
    <title>{agent.name} | Conor Moe</title>
    <style>
      body {
        font-family: system-ui;
        background: #0f172a;
        color: white;
        margin: 0;
        padding: 40px;
      }

      .container {
        max-width: 1200px;
        margin: auto;
      }

      .back-link {
        color: #94a3b8;
        text-decoration: none;
        font-size: 14px;
        display: inline-block;
        margin-bottom: 20px;
      }

      .back-link:hover {
        color: white;
      }

      h1 {
        margin-bottom: 8px;
      }

      .description {
        color: #cbd5e1;
        margin-bottom: 16px;
      }

      .tags {
        margin-bottom: 30px;
      }

      .tag {
        background: #475569;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        margin-right: 5px;
      }

      .embed-frame {
        width: 100%;
        height: 900px;
        border: none;
        border-radius: 12px;
        background: white;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
      }

      .placeholder {
        background: #1e293b;
        padding: 40px;
        border-radius: 12px;
        text-align: center;
        color: #94a3b8;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <a href="/" class="back-link">← Back to all agents</a>

      <h1>{agent.name}</h1>
      <p class="description">{agent.description}</p>

      <div class="tags">
        {agent.tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>

      {agent.embedUrl ? (
        <iframe
          src={agent.embedUrl}
          class="embed-frame"
          title={agent.name}
          loading="lazy"
        ></iframe>
      ) : (
        <div class="placeholder">
          <p>Coming soon — this agent's interface isn't live yet.</p>
        </div>
      )}
    </div>
  </body>
</html>
